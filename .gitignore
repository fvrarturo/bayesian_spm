# Data (large / licensed)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
*.parquet
*.csv
*.h5
*.hdf5
*.npz
*.pkl

# Synthetic data is regenerable from the manifest + generator
data/synthetic/erdos_renyi/
data/synthetic/block_diagonal/
data/synthetic/band/
# keep the manifest itself under version control
!data/synthetic/configs/
data/synthetic/configs/*.json.bak

# Results & figures (regenerable)
results/*
!results/.gitkeep
figures/*
!figures/.gitkeep

# SLURM / job logs
logs/*
!logs/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environments
.env
*.env
